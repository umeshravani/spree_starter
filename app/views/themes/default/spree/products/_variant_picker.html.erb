<% options_param_name ||= :options %>

<% if product.has_variants? %>
  <div id='product-variant-picker' class="flex flex-col gap-y-6 mb-4 mt-2">
    <% product.option_types.each_with_index do |option_type, index| %>
      <% selected_option = product_selected_option_for_option(option_type, product: product, selected_variant: selected_variant, options_param_name: options_param_name) %>
      
      <% if option_type.color_swatch? || (option_type.respond_to?(:kind) && option_type.kind == 'color_swatch') %>
        <%= option_type_colors_preview_styles(option_type).html_safe %>
        <fieldset data-option-id="<%= option_type.id %>" class="flex flex-col gap-y-2">
          <legend class="text-sm font-semibold uppercase tracking-widest text-default">
            <%= option_type.presentation %>: 
            <span class="font-normal text-gray-500"><%= selected_option&.presentation %></span>
          </legend>
          <ul class="flex items-center flex-wrap gap-2" role="listbox" aria-label="<%= option_type.presentation %>">
            <%= render 'spree/products/variant_options', product: product, option_type: option_type, position: index, selected_variant: selected_variant, options_param_name: options_param_name %>
          </ul>
        </fieldset>

      <% elsif option_type.respond_to?(:kind) && option_type.kind == 'buttons' %>
        <fieldset data-option-id="<%= option_type.id %>" class="flex flex-col gap-y-3">
          <legend class="text-sm font-semibold uppercase tracking-widest text-default">
            <%= option_type.presentation %>
          </legend>
          <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="<%= option_type.presentation %>">
            <%= render 'spree/products/variant_options', product: product, option_type: option_type, position: index, selected_variant: selected_variant, options_param_name: options_param_name %>
          </div>
        </fieldset>

      <% else %>
        <fieldset data-option-id="<%= option_type.id %>" class="flex flex-col gap-y-2">
          <legend class="text-sm font-semibold uppercase tracking-widest text-default">
            <%= option_type.presentation %>
          </legend>
          <div data-controller="dropdown" class="relative" role="group">
            <button
              data-action="click->dropdown#toggle click@window->dropdown#hide"
              type='button'
              class='w-full text-sm uppercase tracking-widest flex justify-between items-center border border-default py-3 px-4 rounded-input dropdown-button bg-background'
              data-dropdown-target="button"
              aria-haspopup="listbox"
              aria-label="<%= selected_option ? "#{option_type.presentation}: #{selected_option.presentation}" : Spree.t('storefront.variant_picker.please_choose', option_type: option_type.presentation) %>">
              
              <span id="option-<%= option_type.id %>-value" class="text-default">
                <% if selected_option %>
                  <%= selected_option.presentation %>
                <% else %>
                  <%= Spree.t('storefront.variant_picker.please_choose', option_type: option_type.presentation) %>
                <% end %>
              </span>
              <%= render 'spree/shared/icons/chevron_down', size: 16 %>
            </button>

            <div data-dropdown-target="menu"
                 class="hidden absolute top-12 left-0 z-50 w-full shadow-lg border border-default bg-background overflow-hidden rounded-input">
              <div class="max-h-60 overflow-y-auto">
                <%= render 'spree/products/variant_options', product: product, option_type: option_type, position: index, selected_variant: selected_variant, options_param_name: options_param_name %>
              </div>
            </div>
          </div>
        </fieldset>
      <% end %>
    <% end %>
  </div>
<% end %>